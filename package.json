{
	"name": "av-downloader",
	"version": "0.0.0",
	"license": "MIT",
	"bin": "dist/cli.js",
	"type": "module",
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"docs:generate": "tsx tools/docs/generate-docs.ts",
		"docs:check": "tsx tools/docs/check-generated-docs.ts",
		"lint": "xo",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"test": "prettier --check . && xo",
		"test:docs": "vitest run --config vitest.config.ts",
		"test:docs:coverage": "vitest run --config vitest.config.ts --coverage.enabled"
	},
	"files": [
		"dist"
	],
	"dependencies": {
		"ink": "^6.8.0",
		"meow": "^11.0.0",
		"react": "^19.2.0"
	},
	"devDependencies": {
		"@sindresorhus/tsconfig": "^3.0.1",
		"@types/node": "^20.19.37",
		"@types/react": "^19.2.14",
		"@vdemedes/prettier-config": "^2.0.1",
		"@vitest/coverage-v8": "4.1.0",
		"chalk": "^5.2.0",
		"eslint": "^8.57.1",
		"eslint-config-xo-react": "^0.27.0",
		"eslint-plugin-react": "^7.32.2",
		"eslint-plugin-react-hooks": "^4.6.0",
		"ink-testing-library": "4.0.0",
		"prettier": "^2.8.7",
		"tsx": "4.21.0",
		"typedoc": "0.28.17",
		"typedoc-plugin-markdown": "4.10.0",
		"typescript": "^5.0.3",
		"vitest": "4.1.0",
		"xo": "^0.53.1"
	},
	"xo": {
		"extends": "xo-react",
		"prettier": true,
		"overrides": [
			{
				"files": [
					"tools/**/*.ts",
					"tests/**/*.ts",
					"tests/**/*.tsx",
					"vitest.config.ts"
				],
				"parserOptions": {
					"project": "./tsconfig.tools.json"
				},
				"rules": {
					"import/extensions": "off",
					"n/file-extension-in-import": "off"
				}
			},
			{
				"files": [
					"tools/**/*.ts"
				],
				"rules": {
					"@typescript-eslint/no-unsafe-assignment": "off",
					"@typescript-eslint/no-unsafe-call": "off",
					"@typescript-eslint/no-unsafe-return": "off",
					"@typescript-eslint/restrict-template-expressions": "off"
				}
			},
			{
				"files": [
					"tests/**/*.ts",
					"tests/**/*.tsx"
				],
				"rules": {
					"@typescript-eslint/ban-types": "off",
					"@typescript-eslint/no-unsafe-assignment": "off",
					"@typescript-eslint/no-unsafe-call": "off",
					"@typescript-eslint/no-unsafe-return": "off",
					"@typescript-eslint/restrict-template-expressions": "off"
				}
			},
			{
				"files": [
					"source/downloader/**/*.ts",
					"source/cli.tsx",
					"source/cli-metadata.ts",
					"source/app.tsx",
					"source/cli-ui/**/*.ts",
					"source/cli-ui/**/*.tsx",
					"tests/downloader/**/*.ts",
					"tests/cli/**/*.ts",
					"tests/cli/app.test.tsx",
					"tests/docs/cli-reference.test.ts"
				],
				"rules": {
					"@typescript-eslint/ban-types": "off",
					"@typescript-eslint/class-literal-property-style": "off",
					"@typescript-eslint/naming-convention": "off",
					"@typescript-eslint/no-empty-function": "off",
					"@typescript-eslint/no-unnecessary-type-assertion": "off",
					"@typescript-eslint/padding-line-between-statements": "off",
					"@typescript-eslint/prefer-nullish-coalescing": "off",
					"@typescript-eslint/promise-function-async": "off",
					"@typescript-eslint/restrict-template-expressions": "off",
					"n/prefer-global/buffer": "off",
					"n/prefer-global/process": "off",
					"no-await-in-loop": "off",
					"no-bitwise": "off",
					"no-constant-condition": "off",
					"object-shorthand": "off",
					"prefer-destructuring": "off",
					"react/boolean-prop-naming": "off",
					"react/jsx-sort-props": "off",
					"unicorn/better-regex": "off",
					"unicorn/no-new-array": "off",
					"unicorn/prefer-logical-operator-over-ternary": "off",
					"unicorn/prevent-abbreviations": "off"
				}
			}
		],
		"rules": {
			"react/prop-types": "off",
			"react/react-in-jsx-scope": "off",
			"react/jsx-uses-react": "off",
			"unicorn/expiring-todo-comments": "off"
		}
	},
	"prettier": "@vdemedes/prettier-config"
}
